# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=change-this-database-password
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=change-this-admin-password

# Flask Configuration
DATABASE_URL=postgresql://your_database_user:change-this-database-password@localhost:5432/your_database_name
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development
FLASK_DEBUG=True

# Admin Login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password

# External APIs
# Get your Google Maps API key from: https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Get WAQI API token from: https://waqi.info/api-binding-gui/
WAQI_API_TOKEN=your-waqi-api-token

# Get OpenAQ API key from: https://openaq.org/
OPENAQ_API_KEY=your-openaq-api-key

# PDF Export Service
PDF_EXPORT_SERVICE_URL=http://localhost:3000
PDF_SERVICE_PORT=3000

# Logging
LOG_LEVEL=INFO

# Application
APP_PORT=5000
APP_HOST=localhost
